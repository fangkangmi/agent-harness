{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Per-developer permission allowlist. Copy to settings.local.json (gitignored) and edit. Easier: run /permissions inside Claude Code.",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)"
    ],
    "deny": []
  }
}
